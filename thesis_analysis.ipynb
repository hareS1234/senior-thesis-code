# Cell 0: Imports & matplotlib style

import os
from pathlib import Path

import numpy as np
import pandas as pd

import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA
from sklearn.linear_model import LinearRegression
from sklearn.metrics import r2_score

import statsmodels.api as sm

# Matplotlib / seaborn style (Princeton-thesis-ish)
plt.rcParams.update({
    "figure.figsize": (6, 4),
    "font.family": "serif",
    "font.size": 12,
    "axes.labelsize": 12,
    "axes.titlesize": 14,
    "xtick.labelsize": 10,
    "ytick.labelsize": 10,
    "legend.fontsize": 10,
    "savefig.dpi": 300,
})

sns.set_context("talk", rc={"font.size": 12, "axes.titlesize": 14, "axes.labelsize": 12})
sns.set_style("whitegrid")


# Cell 1: Load data

PROJECT_ROOT = Path("/scratch/gpfs/JERELLE/harry/thesis_data/LAMMPS_uncapped")
SUMMARY_PATH = PROJECT_ROOT / "BIG_SUMMARY" / "all_sequences_summary.csv"

df = pd.read_csv(SUMMARY_PATH)

print("Data shape:", df.shape)
df.head()


# Cell 2: Basic cleaning and derived columns

df.columns

# Cell 3: Infer monomer/dimer from sequence_id (adjust if needed)

if "sequence_id" in df.columns:
    # Example heuristic – tweak to match your naming scheme
    def classify_monomer_dimer(s):
        s = str(s).lower()
        if "dimer" in s or "_dimer" in s:
            return "dimer"
        elif "monomer" in s or "_monomer" in s:
            return "monomer"
        else:
            return "unknown"

    df["system_type"] = df["sequence_id"].apply(classify_monomer_dimer)
else:
    df["system_type"] = "unknown"

df["system_type"].value_counts()

# Cell 4: Identify numeric columns and define key names

numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
print("Numeric columns:", numeric_cols)

# Try to guess some canonical column names, with fallbacks
col_N_min = "N_min" if "N_min" in df.columns else None
col_tau1 = "tau1" if "tau1" in df.columns else None
col_ramanujan = "ramanujan_score" if "ramanujan_score" in df.columns else None

# Dijkstra stats
col_dist_mean = "dist_mean" if "dist_mean" in df.columns else None
col_dist_max = "dist_max" if "dist_max" in df.columns else None

# Graph stats
col_deg = "avg_degree" if "avg_degree" in df.columns else None
col_clust = "avg_clustering" if "avg_clustering" in df.columns else None
col_aspl = "avg_shortest_path" if "avg_shortest_path" in df.columns else None

print("Detected columns:",
      "\nN_min:", col_N_min,
      "\ntau1:", col_tau1,
      "\nRamanujan:", col_ramanujan)

# Cell 5: Derived variables (log-scales etc.)

df_derived = df.copy()

if col_tau1 is not None:
    df_derived = df_derived[df_derived[col_tau1] > 0].copy()
    df_derived["log_tau1"] = np.log10(df_derived[col_tau1])

if col_N_min is not None:
    df_derived = df_derived[df_derived[col_N_min] > 0].copy()
    df_derived["log_N_min"] = np.log10(df_derived[col_N_min])

# Example "funnelness" index – tweak later if you define a more physical one
# Here: larger tau1 and smaller dist_mean → more funneled
if col_tau1 is not None and col_dist_mean is not None:
    df_derived["funnel_index"] = df_derived[col_tau1] / df_derived[col_dist_mean]

df_derived.head()

# Cell 6: Distributions of key descriptors

plot_cols = [c for c in [
    col_N_min, col_tau1, col_dist_mean, col_dist_max,
    col_deg, col_clust, col_aspl, col_ramanujan,
    "funnel_index" if "funnel_index" in df_derived.columns else None
] if c is not None and c in df_derived.columns]

n = len(plot_cols)
print("Plotting histograms for:", plot_cols)

fig, axes = plt.subplots(nrows=int(np.ceil(n/2)), ncols=2, figsize=(10, 4*int(np.ceil(n/2))))
axes = axes.flatten()

for ax, col in zip(axes, plot_cols):
    sns.histplot(df_derived[col], kde=True, ax=ax)
    ax.set_title(col)
    ax.set_xlabel(col)

for ax in axes[len(plot_cols):]:
    ax.axis("off")

plt.tight_layout()
plt.show()

# Cell 7: Correlation heatmap

corr = df_derived[plot_cols].corr()

plt.figure(figsize=(8, 6))
sns.heatmap(corr, annot=True, fmt=".2f", cmap="coolwarm", square=True, cbar_kws={"shrink": 0.8})
plt.title("Correlation of Landscape Descriptors")
plt.tight_layout()
plt.show()

# Cell 8: PCA setup

# Choose features for PCA: numerical columns, but drop any obvious non-structural things if needed
pca_features = [c for c in numeric_cols if c not in []]  # you can manually drop things here

print("PCA features:", pca_features)

X = df_derived[pca_features].values
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

pca = PCA(n_components=4)
X_pca = pca.fit_transform(X_scaled)

explained = pca.explained_variance_ratio_
print("Explained variance ratio:", explained)

# Cell 9: PCA scatter colored by monomer/dimer

df_pca = df_derived.copy()
df_pca["PC1"] = X_pca[:, 0]
df_pca["PC2"] = X_pca[:, 1]

plt.figure(figsize=(6, 5))
sns.scatterplot(
    data=df_pca,
    x="PC1", y="PC2",
    hue="system_type",
    style="system_type",
    s=70
)
plt.axhline(0, color="gray", linewidth=0.5)
plt.axvline(0, color="gray", linewidth=0.5)
plt.title("PCA of Energy Landscape Descriptors")
plt.tight_layout()
plt.show()

# Cell 10: Scree plot

plt.figure(figsize=(6, 4))
components = np.arange(1, len(explained) + 1)
plt.plot(components, explained * 100, marker="o")
plt.xticks(components)
plt.ylabel("Explained Variance (%)")
plt.xlabel("Principal Component")
plt.title("PCA Scree Plot")
plt.tight_layout()
plt.show()

# Cell 11: Ramanujan vs log_tau1

if col_ramanujan is not None and "log_tau1" in df_derived.columns:
    plt.figure(figsize=(6, 5))
    sns.scatterplot(
        data=df_derived,
        x=col_ramanujan,
        y="log_tau1",
        hue="system_type",
        style="system_type",
        s=70
    )
    sns.regplot(
        data=df_derived,
        x=col_ramanujan,
        y="log_tau1",
        scatter=False,
        ci=95,
        line_kws={"linewidth": 2, "alpha": 0.7}
    )
    plt.xlabel("Ramanujan Score")
    plt.ylabel(r"$\log_{10}(\tau_1)$")
    plt.title("Ramanujan Score vs Slowest Relaxation Timescale")
    plt.tight_layout()
    plt.show()

# Cell 12: dist_mean vs N_min

if col_N_min is not None and col_dist_mean is not None:
    plt.figure(figsize=(6, 5))
    sns.scatterplot(
        data=df_derived,
        x=col_N_min,
        y=col_dist_mean,
        hue="system_type",
        style="system_type",
        s=70
    )
    sns.regplot(
        data=df_derived,
        x=col_N_min,
        y=col_dist_mean,
        scatter=False,
        ci=95,
        line_kws={"linewidth": 2, "alpha": 0.7}
    )
    plt.xlabel("Number of Minima")
    plt.ylabel("Mean Dijkstra Distance")
    plt.title("Landscape Extent vs Number of Minima")
    plt.tight_layout()
    plt.show()

# Cell 13: funnel_index vs Ramanujan score

if "funnel_index" in df_derived.columns and col_ramanujan is not None:
    plt.figure(figsize=(6, 5))
    sns.scatterplot(
        data=df_derived,
        x=col_ramanujan,
        y="funnel_index",
        hue="system_type",
        style="system_type",
        s=70
    )
    sns.regplot(
        data=df_derived,
        x=col_ramanujan,
        y="funnel_index",
        scatter=False,
        ci=95,
        line_kws={"linewidth": 2, "alpha": 0.7}
    )
    plt.xlabel("Ramanujan Score")
    plt.ylabel("Funnel Index (τ₁ / mean distance)")
    plt.title("Graph Expansion vs Funnel-like Dynamics")
    plt.tight_layout()
    plt.show()

# Cell 14: Build regression dataset

reg_cols = []

if "log_tau1" in df_derived.columns:
    target_col = "log_tau1"
else:
    target_col = col_tau1  # fallback to raw tau1

for c in [col_N_min, col_dist_mean, col_deg, col_clust, col_aspl, col_ramanujan]:
    if c is not None and c in df_derived.columns:
        reg_cols.append(c)

print("Regression predictors:", reg_cols)
print("Regression target:", target_col)

reg_df = df_derived.dropna(subset=[target_col] + reg_cols).copy()
reg_df.shape

# Cell 15: Statsmodels OLS

X = reg_df[reg_cols]
X = sm.add_constant(X)
y = reg_df[target_col]

model = sm.OLS(y, X).fit()
print(model.summary())

# Cell 16: Sklearn regression and coefficient bar plot

lin = LinearRegression()
lin.fit(reg_df[reg_cols], reg_df[target_col])

y_pred = lin.predict(reg_df[reg_cols])
r2 = r2_score(reg_df[target_col], y_pred)
print("In-sample R^2:", r2)

coef_series = pd.Series(lin.coef_, index=reg_cols)

plt.figure(figsize=(6, 4))
coef_series.sort_values().plot(kind="barh")
plt.axvline(0, color="black", linewidth=0.8)
plt.xlabel("Coefficient")
plt.title(f"Linear Model Coefficients (target={target_col}, R²={r2:.2f})")
plt.tight_layout()
plt.show()

# Cell 17: OPTIONAL – merge with sequence features

SEQ_FEAT_PATH = PROJECT_ROOT / "sequence_features.csv"  # change if needed

if SEQ_FEAT_PATH.exists():
    seq_df = pd.read_csv(SEQ_FEAT_PATH)
    print("Seq feature columns:", seq_df.columns)

    if "sequence_id" in df_derived.columns and "sequence_id" in seq_df.columns:
        df_merged = df_derived.merge(seq_df, on="sequence_id", how="left")
        print("Merged shape:", df_merged.shape)
    else:
        df_merged = df_derived.copy()
        print("sequence_id not in both tables – adjust column names.")
else:
    print("No sequence_features.csv found – skipping merge.")
    df_merged = df_derived.copy()

# Cell 18: Helper function to save figures with consistent naming

FIG_DIR = PROJECT_ROOT / "figures"
FIG_DIR.mkdir(exist_ok=True, parents=True)

def save_current_fig(name):
    png_path = FIG_DIR / f"{name}.png"
    pdf_path = FIG_DIR / f"{name}.pdf"
    plt.savefig(png_path, bbox_inches="tight")
    plt.savefig(pdf_path, bbox_inches="tight")
    print(f"Saved {png_path} and {pdf_path}")

